{
  "name": "google-image-to-png",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3939",
    "build": "next build",
    "start": "next start -p 3939",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "build:check": "pnpm -s scripts:build && node dist-scripts/scripts/build-check.js",
    "verify:task": "pnpm -s scripts:build && node dist-scripts/scripts/verify-task.js",
    "hooks:install": "pnpm -s scripts:build && node dist-scripts/scripts/setup-git-hooks.js",
    "harness:check": "pnpm -s scripts:build && node dist-scripts/scripts/harness-check.js",
    "scripts:build": "tsc -p tsconfig.scripts.json --incremental false",
    "prepare": "pnpm -s hooks:install",
    "process:pet": "pnpm -s scripts:build && node dist-scripts/scripts/process-pet-input-folders.js",
    "process:alibaba": "pnpm -s scripts:build && node dist-scripts/scripts/process-alibaba-input-folders.js",
    "process:eye": "pnpm -s scripts:build && node dist-scripts/scripts/process-input-folders.js",
    "category:pet": "pnpm -s scripts:build && node dist-scripts/scripts/generate-keyword-category-txt.js 애견",
    "category:eye": "pnpm -s scripts:build && node dist-scripts/scripts/generate-keyword-category-txt.js 안과",
    "upload:blog": "pnpm -s scripts:build && node dist-scripts/scripts/upload-all-products.js",
    "upload:root": "pnpm -s scripts:build && node dist-scripts/scripts/upload-output-root.js",
    "upload:pet:all": "pnpm -s upload:root -- \"./_samples/output/애견_출력\"",
    "upload:eye:all": "pnpm -s upload:root -- \"./_samples/output/안과_출력\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@google-cloud/storage": "^7.18.0",
    "@tailwindcss/postcss": "^4.1.13",
    "clsx": "latest",
    "jotai": "latest",
    "jszip": "latest",
    "next": "latest",
    "p-limit": "^7.2.0",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "latest",
    "tailwind-merge": "latest",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/uuid": "^11.0.0",
    "autoprefixer": "latest",
    "dotenv": "^17.2.3",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "^4.0.18"
  }
}
