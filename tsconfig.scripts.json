{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist-scripts",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/build-check.ts",
    "scripts/lib/**/*.ts",
    "scripts/check-commit-message.ts",
    "scripts/harness-check.ts",
    "scripts/setup-git-hooks.ts",
    "scripts/verify-task.ts",
    "scripts/process-pet-input-folders.ts",
    "scripts/process-alibaba-input-folders.ts",
    "scripts/process-input-folders.ts",
    "scripts/generate-keyword-category-txt.ts",
    "scripts/upload-all-products.ts",
    "scripts/upload-output-root.ts",
    "scripts/light-distortion-5x.ts",
    "scripts/apply-light-distortion-batch.ts"
  ],
  "exclude": [
    "scripts/__tests__/**"
  ]
}
